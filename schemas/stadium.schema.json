{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "rawantv://schemas/stadium.json",
  "title": "Stadium",
  "type": "object",
  "required": ["id", "name"],
  "properties": {
    "id":       { "type": "string", "pattern": "^stadium_[a-z0-9_]+$" },
    "name":     { "type": "string" },
    "city":     { "type": ["string", "null"] },
    "country":  { "type": ["string", "null"] },
    "capacity": { "type": ["integer", "null"], "minimum": 0 },
    "location": {
      "type": ["object", "null"],
      "properties": {
        "lat": { "type": "number" },
        "lon": { "type": "number" }
      }
    },
    "image":  { "type": ["string", "null"], "format": "uri" },
    "sources": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  },
  "additionalProperties": false
}
